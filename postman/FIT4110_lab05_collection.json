{
  "info": {
    "name": "FIT4110 Lab05 Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "Health API",
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "{{baseUrl}}/health",
          "host": ["{{baseUrl}}"],
          "path": ["health"]
        }
      }
    },
    {
      "name": "Create reading (predict)",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "Authorization", "value": "Bearer {{authToken}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{ \"device_id\": \"ESP32-LAB-A01\", \"metric\": \"temperature\", \"value\": 22.5, \"unit\": \"celsius\", \"timestamp\": \"2026-06-17T01:00:00+00:00\" }"
        },
        "url": {
          "raw": "{{baseUrl}}/readings",
          "host": ["{{baseUrl}}"],
          "path": ["readings"]
        }
      }
    }
  ]
}
